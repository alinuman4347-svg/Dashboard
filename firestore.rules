rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // An admin is a signed-in user whose verified login email is in the list.
    // Anonymous "View Dashboard" guests have no email → never admin.
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'numan.ali@symufolk.com';
    }

    // Dashboard records:
    //   READ  — any signed-in user (admin or guest/viewer).
    //   WRITE — admins only. Viewers are denied at the backend even if they
    //           bypass the UI via devtools, URLs, or direct API calls.
    match /records/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Everything else is denied by default.
  }
}
