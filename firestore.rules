rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Dashboard records — open access so the app can read/write.
    // NOTE: this allows anyone with your config to read/write. Fine for an
    // internal tool; tighten with Firebase Auth before exposing publicly.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
