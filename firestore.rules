rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // An admin is a signed-in user whose roles/{uid} doc says role == 'admin'.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/roles/$(request.auth.uid))
        && get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Dashboard records ---
    // Any signed-in user (admin or viewer) may READ.
    // Only admins may CREATE / UPDATE / DELETE. Viewers are denied at the
    // backend even if they bypass the UI via devtools, URLs, or the API.
    match /records/{id} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // --- Role assignments ---
    // A user may read ONLY their own role doc. Roles are never writable from
    // the client — assign them from the Firebase console (or Admin SDK).
    match /roles/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Everything else is denied by default.
  }
}
